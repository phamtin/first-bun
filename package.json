{
	"name": "kamdo",
	"version": "1.0.0",
	"private": true,
	"workspaces": ["apps/*"],
	"scripts": {
		"lint": "bun tsc --noEmit && bunx biome lint --write ./src",
		"dev": "bun lint && bun run --watch src/pkgs/api/index.ts",
		"dcu": "docker compose -f ./docker-compose.dev.yaml up --build -w",
		"dcd": "docker compose -f ./docker-compose.dev.yaml down --remove-orphans"
	},

	"module": "./src/index"
}
